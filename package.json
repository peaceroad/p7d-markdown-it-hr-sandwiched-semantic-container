{
  "name": "@peaceroad/markdown-it-hr-sandwiched-semantic-container",
  "version": "0.14.0",
  "description": "A markdown-it plugin. If a paragraph group is sandwiched between two hr elements of the same symbol type, and the first word of the paragraph group has a semantic meaning, then the paragraph group change to a semantic container.",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20.18.3"
  },
  "files": [
    "index.js",
    "semantics/",
    "src/",
    "docs/semantic-catalog.md",
    "docs/semantic-catalog_ja.md",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node test/test.js",
    "labels:audit": "node scripts/label-audit.js",
    "labels:audit:strict": "node scripts/label-audit.js --strict",
    "performance": "node test/performance/performance-test.js full",
    "performance:quick": "node test/performance/performance-test.js quick",
    "performance:ab": "node test/performance/performance-test.js ab",
    "performance:order": "node test/performance/performance-test.js order",
    "performance:features": "node test/performance/performance-test.js features",
    "performance:memory": "node --expose-gc test/performance/performance-test.js full",
    "docs:semantic-catalog": "node docs/generate-semantic-catalog.js"
  },
  "repository": "https://github.com/peaceroad/p7d-markdown-it-hr-sandwiched-semantic-container",
  "author": "peaceroad <peaceroad@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@peaceroad/markdown-it-cjk-breaks-mod": "^0.1.14",
    "@peaceroad/markdown-it-figure-with-p-caption": "^0.19.0",
    "@peaceroad/markdown-it-footnote-here": "^0.6.1",
    "@peaceroad/markdown-it-strong-ja": "^0.9.4",
    "markdown-it": "^14.3.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-front-matter": "^0.2.4",
    "markdown-it-meta": "^0.0.1"
  }
}
